# vMix Logger Configuration

# Machine Name
MACHINE_NAME="test machine"

# vMix machine IP (use 'localhost' if running on same PC as vMix)
VMIX_HOST=localhost

# vMix HTTP API port (default 8088)
VMIX_PORT=8088

# vMix TCP API port (default 8099)
VMIX_TCP_PORT=8099

# How often to poll via HTTP in milliseconds (fallback / double-check)
POLL_INTERVAL_MS=3000

# Web dashboard port
PORT=3000

#sync endpoint
CENTRAL_API_URL=https://vmixmonitor.hillcom.ug/api/newdata
