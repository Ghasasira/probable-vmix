{
  "name": "vmix-logger",
  "version": "1.0.0",
  "description": "Automatically logs every input played in vMix with timestamps, screenshots, and web dashboard",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "build": "pkg . --out-path=dist/"
  },
  "bin": "index.js",
  "pkg": {
    "scripts": [
      "paths.js",
      "server.js",
      "db.js",
      "export.js",
      "vmix-http.js",
      "vmix-tcp.js"
    ],
    "assets": [
      "index.html",
      ".env",
      "node_modules/es-get-iterator/**/*",
      "node_modules/sql.js/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "options": [
      "no-bytecode"
    ]
  },
  "keywords": [
    "vmix",
    "logger",
    "broadcast",
    "video-production"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "pdfkit": "^0.14.0",
    "sql.js": "^1.10.0",
    "xml2js": "^0.6.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
